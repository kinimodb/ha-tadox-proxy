      "eco_target": {
        "default": "mdi:leaf"
      },
      "boost_target": {
        "default": "mdi:rocket-launch"
      },
      "away_target": {
        "default": "mdi:home-export-outline"
      },
      "frost_protection_target": {
        "default": "mdi:snowflake"
      }
